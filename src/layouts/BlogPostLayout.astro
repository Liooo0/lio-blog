---
import BaseLayout from './BaseLayout.astro';
import { render, type CollectionEntry } from 'astro:content';
import TagBadge from '../components/TagBadge.astro';
import { SITE } from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, tags } = post.data;
const { Content } = await render(post);
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-10">
      <time class="text-sm text-surface-700 dark:text-surface-400 font-mono">
        {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight">{title}</h1>
      <p class="mt-3 text-lg text-surface-700 dark:text-surface-400">{description}</p>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => <TagBadge name={tag} />)}
        </div>
      )}
    </header>

    <div class="prose dark:prose-invert prose-lg">
      <Content />
    </div>
  </article>

  <nav class="mt-16 pt-8 border-t border-surface-200 dark:border-surface-800">
    <a href={`${SITE.base}/blog`} class="text-sm text-surface-700 dark:text-surface-400 hover:text-accent-500 transition-colors">
      ← 返回博客列表
    </a>
  </nav>
</BaseLayout>
