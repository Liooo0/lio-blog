---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Collect all unique tags
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="博客">
  <section class="py-8">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">博客</h1>
    <p class="mt-3 text-lg text-surface-700 dark:text-surface-400">
      技术笔记、项目复盘和随便写写
    </p>

    {allTags.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2">
        <a
          href="?tag="
          class="text-xs px-3 py-1 rounded-full bg-surface-100 dark:bg-surface-800 hover:bg-surface-200 dark:hover:bg-surface-700 transition-colors"
        >
          全部
        </a>
        {allTags.map((tag) => (
          <a
            href={`?tag=${tag}`}
            class="text-xs px-3 py-1 rounded-full bg-surface-100 dark:bg-surface-800 hover:bg-surface-200 dark:hover:bg-surface-700 transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="mt-4 space-y-1 divide-y divide-surface-100 dark:divide-surface-800">
    {posts.map((post) => (
      <BlogCard
        title={post.data.title}
        description={post.data.description}
        date={post.data.date}
        slug={post.id}
        tags={post.data.tags}
      />
    ))}
  </section>

  {posts.length === 0 && (
    <p class="text-surface-700 dark:text-surface-400 text-center py-20">
      还没有文章，敬请期待。
    </p>
  )}
</BaseLayout>
