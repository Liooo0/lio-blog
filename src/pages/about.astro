---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SOCIAL } from '../consts';
---

<BaseLayout title="关于">
  <section class="py-12">
    <span class="inline-block text-sm font-mono text-accent-600 dark:text-accent-400 mb-3 px-3 py-1 rounded-full bg-accent-50 dark:bg-accent-950/50 border border-accent-200/50 dark:border-accent-800/50">
      👤 About
    </span>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">关于我</h1>

    <div class="mt-10 prose dark:prose-invert prose-lg">
      <p class="text-xl text-surface-600 dark:text-surface-400 leading-relaxed">
        嘿，我是 <strong class="text-surface-900 dark:text-surface-100">lio</strong>，24 岁，现居深圳。
      </p>

      <h2>💻 技术</h2>
      <p>
        对 AI Agent、前端开发、高性能计算感兴趣。喜欢探索新工具，追求极致性能和性价比。
      </p>
      <ul>
        <li>主力台式机：9800X3D + RTX 4090</li>
        <li>移动办公：MacBook</li>
        <li>存储：自建 NAS</li>
      </ul>

      <h2>📸 爱好</h2>
      <ul>
        <li><strong>摄影</strong> — S5M2，日出 / 风景 / 星空。三个月全职测试后转长期并行</li>
        <li><strong>汽车</strong> — Honda Fit GK5 手动挡，JDM 和性能车爱好者</li>
        <li><strong>游戏</strong> — CS2、PUBG、三角洲、鸣潮</li>
        <li><strong>音乐</strong> — 吉他初学者，近期目标 D 大调《卡农》</li>
        <li><strong>健身</strong> — 系统健身，5 周增肌</li>
      </ul>

      <h2>🌐 这个博客</h2>
      <p>
        用 <strong>Astro</strong> + <strong>Tailwind CSS</strong> 搭建，托管在 <strong>GitHub Pages</strong>。
        所有内容用 MDX 编写，Git 管理，完全自主可控，无平台锁定。
      </p>

      <h2>🔗 找到我</h2>
      <p>
        <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-surface-100 dark:bg-surface-800 hover:bg-surface-200 dark:hover:bg-surface-700 transition-colors not-prose no-underline font-medium">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
