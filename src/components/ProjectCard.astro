---
import TagBadge from './TagBadge.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  description: string;
  slug: string;
  tech: string[];
  status: 'completed' | 'in-progress' | 'planned';
  repo?: string;
  demo?: string;
}

const { title, description, slug, tech, status, repo, demo } = Astro.props;

const statusConfig = {
  completed: { label: '✅ 已完成', class: 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-400 border-emerald-200 dark:border-emerald-800' },
  'in-progress': { label: '🚧 进行中', class: 'bg-amber-50 text-amber-700 dark:bg-amber-950/40 dark:text-amber-400 border-amber-200 dark:border-amber-800' },
  planned: { label: '💡 计划中', class: 'bg-surface-50 text-surface-600 dark:bg-surface-900 dark:text-surface-400 border-surface-200 dark:border-surface-700' },
};
---

<article class="group relative rounded-xl border border-surface-200 dark:border-surface-800 bg-surface-50/50 dark:bg-surface-900/50 hover:border-accent-300 dark:hover:border-accent-800 hover:shadow-lg dark:hover:shadow-none transition-all duration-300 overflow-hidden">
  <a href={`${SITE.base}/projects/${slug}`} class="block p-5">
    <div class="flex items-start justify-between gap-3 mb-3">
      <h3 class="text-base sm:text-lg font-semibold group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors leading-snug">
        {title}
      </h3>
    </div>
    <p class="text-sm text-surface-600 dark:text-surface-400 line-clamp-2 leading-relaxed">
      {description}
    </p>
    {tech.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {tech.map((t) => <TagBadge name={t} />)}
      </div>
    )}
  </a>
  <div class="flex items-center justify-between px-5 pb-4">
    <span class={`inline-flex items-center text-xs px-2.5 py-1 rounded-full border font-medium ${statusConfig[status].class}`}>
      {statusConfig[status].label}
    </span>
    <div class="flex gap-3">
      {repo && (
        <a href={repo} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-surface-500 hover:text-surface-800 dark:hover:text-surface-200 transition-colors flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          源码
        </a>
      )}
      {demo && (
        <a href={demo} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-accent-600 dark:text-accent-400 hover:text-accent-700 dark:hover:text-accent-300 transition-colors flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          演示
        </a>
      )}
    </div>
  </div>
</article>
