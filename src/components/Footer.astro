---
import { SITE } from '../consts';
---

<footer class="border-t border-surface-200 dark:border-surface-800 mt-20">
  <div class="mx-auto max-w-3xl px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-surface-700 dark:text-surface-400">
    <p>&copy; {new Date().getFullYear()} {SITE.author}. Built with Astro.</p>
    <div class="flex items-center gap-4">
      <a href="/rss.xml" class="hover:text-accent-500 transition-colors">RSS</a>
      <a href="https://github.com/lio846" class="hover:text-accent-500 transition-colors" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</footer>
