---
import TagBadge from './TagBadge.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
}

const { title, description, date, slug, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class="group">
  <a href={`${SITE.base}/blog/${slug}`} class="block p-5 -mx-5 rounded-xl hover:bg-white dark:hover:bg-surface-900 hover:shadow-md dark:hover:shadow-none transition-all duration-300 border border-transparent hover:border-surface-200 dark:hover:border-surface-800">
    <div class="flex items-start gap-4">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1.5">
          <time class="text-xs text-surface-500 dark:text-surface-400 font-mono">{formattedDate}</time>
        </div>
        <h3 class="text-base sm:text-lg font-semibold group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors leading-snug">
          {title}
        </h3>
        <p class="mt-1.5 text-sm text-surface-600 dark:text-surface-400 line-clamp-2 leading-relaxed">
          {description}
        </p>
        {tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5">
            {tags.map((tag) => <TagBadge name={tag} />)}
          </div>
        )}
      </div>
      <div class="hidden sm:flex shrink-0 w-1 self-stretch rounded-full bg-accent-200 dark:bg-accent-800 group-hover:bg-accent-400 dark:group-hover:bg-accent-600 transition-colors"></div>
    </div>
  </a>
</article>
